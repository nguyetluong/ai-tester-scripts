  "item": [
    {
      "name": "GET Users Page 2",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time less than 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test('Page is 2', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.page).to.eql(2);",
              "});",
              "",
              "pm.test('Data array is not empty', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.data).to.be.an('array');",
              "    pm.expect(body.data.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/users?page=2",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contains created user', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.name).to.eql('AI Tester');",
              "    pm.expect(body.job).to.eql('QA');",
              "    pm.expect(body.id).to.exist;",
              "    pm.expect(body.createdAt).to.exist;",
              "});",
              "",
              "pm.test('Save user id to environment', function () {",
              "    const body = pm.response.json();",
              "    pm.environment.set('created_user_id', body.id);",
              "    pm.expect(pm.environment.get('created_user_id')).to.eql(body.id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\":\"AI Tester\",\n    \"job\":\"QA\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      },
      "response": []
    },
