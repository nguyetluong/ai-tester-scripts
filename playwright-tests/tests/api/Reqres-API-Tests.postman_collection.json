    {
      "name": "POST Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains token', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.token).to.exist;",
              "    pm.expect(body.token).to.be.a('string');",
              "});",
              "",
              "pm.test('Save auth token', function () {",
              "    const body = pm.response.json();",
              "    pm.environment.set('auth_token', body.token);",
              "    pm.expect(pm.environment.get('auth_token')).to.eql(body.token);",
              "});",
              "",
              "pm.test('Response time less than 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
